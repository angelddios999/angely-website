# Local Worker secrets for `astro dev` / `wrangler dev`
# Copy to `.dev.vars` (gitignored) and fill in real values.
# These map to env.TURNSTILE_SECRET_KEY and env.RESEND_API_KEY on the Worker.

TURNSTILE_SECRET_KEY=your-turnstile-secret-key-here
RESEND_API_KEY=re_your-resend-api-key-here

# Optional: who the contact form emails as / to (defaults used if unset)
# CONTACT_FROM_EMAIL=portfolio@yourdomain.com
# CONTACT_TO_EMAIL=you@yourdomain.com
