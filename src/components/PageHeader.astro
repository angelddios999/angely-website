---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
}

const { eyebrow, title, description } = Astro.props;
---

<header class="border-b border-line/80 bg-gradient-to-b from-accent-soft/40 to-transparent">
  <div class="container-page section-y !pb-12 !pt-14 sm:!pb-14 sm:!pt-16">
    {eyebrow && <p class="eyebrow">{eyebrow}</p>}
    <h1 class="mt-3 max-w-3xl font-display text-4xl font-semibold tracking-tight text-ink sm:text-5xl">
      {title}
    </h1>
    {
      description && (
        <p class="mt-4 max-w-2xl text-base leading-relaxed text-ink-muted sm:text-lg">
          {description}
        </p>
      )
    }
    <slot />
  </div>
</header>
