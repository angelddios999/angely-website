---
export const prerender = true;

import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Page not found" description="This page doesn't exist.">
  <section class="container-page flex min-h-[50dvh] flex-col items-start justify-center py-20">
    <p class="eyebrow">404</p>
    <h1 class="mt-3 font-display text-4xl font-semibold text-ink sm:text-5xl">
      This page wandered off the page.
    </h1>
    <p class="mt-4 max-w-md text-ink-muted">
      The link may be outdated, or the piece may have moved. Head home and explore from there.
    </p>
    <a href="/" class="btn-primary mt-8">Back home</a>
  </section>
</BaseLayout>
