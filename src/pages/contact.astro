---
// Server-rendered so PUBLIC_TURNSTILE_SITE_KEY can come from Worker vars
// (dashboard) without a rebuild. Still falls back to build-time import.meta.env.
export const prerender = false;

import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import ContactForm from "../components/ContactForm.astro";
import { site } from "../data/site";
import { env } from "cloudflare:workers";

const siteKey =
  (import.meta.env.PUBLIC_TURNSTILE_SITE_KEY as string | undefined)?.trim() ||
  (env.PUBLIC_TURNSTILE_SITE_KEY as string | undefined)?.trim() ||
  "";
---

<BaseLayout title="Contact" description={`Contact ${site.shortName}.`}>
  <PageHeader
    eyebrow="Contact"
    title="Say hello"
    description="TODO: replace — short note about response time / what kinds of messages are welcome."
  />

  <section class="section-y">
    <div class="container-page grid gap-12 lg:grid-cols-[0.9fr_1.1fr]">
      <div>
        <h2 class="font-display text-2xl font-semibold text-ink">Other ways to reach out</h2>
        <p class="mt-3 text-sm leading-relaxed text-ink-muted">
          Prefer email directly? Use the address below, or send a note through the form —
          it goes through Cloudflare Turnstile and Resend on the Worker.
        </p>
        <p class="mt-6">
          <span class="eyebrow">Email</span>
          <a
            href={`mailto:${site.contact.email}`}
            class="mt-1 block text-lg font-medium text-ink link-underline"
          >
            {site.contact.email}
          </a>
          <span class="mt-1 block text-xs text-amber-800"
            >TODO: replace contact email in src/data/site.ts</span
          >
        </p>
      </div>
      <div class="rounded-2xl border border-line bg-canvas-elevated p-6 shadow-soft sm:p-8">
        <ContactForm siteKey={siteKey} />
      </div>
    </div>
  </section>
</BaseLayout>
