---
export const prerender = true;

import BaseLayout from "../layouts/BaseLayout.astro";
import PhotoGrid from "../components/PhotoGrid.astro";
import { site } from "../data/site";
import {
  getFeatured,
  galleryHrefFor,
  physicalArt,
  digitalArt,
  cartoons,
  animations,
} from "../data/portfolio";

const { art } = getFeatured();
const featured = art.slice(0, 6);
---

<BaseLayout title={site.title}>
  <!-- Hero -->
  <section class="relative overflow-hidden border-b border-line">
    <div
      class="pointer-events-none absolute -right-24 -top-24 h-80 w-80 rounded-full bg-accent-soft/80 blur-3xl"
      aria-hidden="true"
    >
    </div>
    <div
      class="pointer-events-none absolute -bottom-32 -left-16 h-72 w-72 rounded-full bg-sky-100/70 blur-3xl"
      aria-hidden="true"
    >
    </div>
    <div class="container-page relative grid gap-12 py-16 sm:py-20 lg:grid-cols-[1.15fr_0.85fr] lg:items-start lg:py-28">
      <div>
        <p class="eyebrow">Art · Illustration · Cartoons · Animation</p>
        <h1 class="mt-4 font-display text-4xl font-semibold tracking-tight text-ink sm:text-5xl lg:text-6xl lg:leading-[1.08]">
          Pictures that hold still — and ones that move.
        </h1>
        <p class="mt-6 max-w-xl text-base leading-relaxed text-ink-muted sm:text-lg">
          <!-- TODO: replace intro copy -->
          Welcome to {site.shortName}'s portfolio — a growing collection of physical drawings,
          digital art, cartoons of people and animals, and short animations. Explore the work,
          then get in touch.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href="/physical" class="btn-primary">Browse physical art</a>
          <a href="/cartoons" class="btn-secondary">See cartoons</a>
          <a href="/animations" class="btn-secondary">Watch animations</a>
        </div>
      </div>

      <!-- Featured preview cards (placeholders until R2 media is live) -->
      <div class="grid grid-cols-2 gap-3 sm:gap-4">
        {
          featured.slice(0, 3).map((item, i) => (
            <a
              href={galleryHrefFor(item)}
              class:list={[
                "card-media relative block",
                i === 0 && "col-span-2 aspect-[16/10]",
                i !== 0 && "aspect-square",
              ]}
            >
              <div
                class="absolute inset-0"
                style={`background: linear-gradient(145deg, hsl(${item.placeholderHue ?? 30} 28% 78%), hsl(${((item.placeholderHue ?? 30) + 50) % 360} 20% 60%))`}
              />
              {item.placeholder && (
                <span class="placeholder-badge">TODO: replace</span>
              )}
              <div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-black/50 to-transparent p-3 pt-8">
                <p class="text-sm font-medium text-white">{item.title}</p>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Short intro + stats -->
  <section class="section-y border-b border-line">
    <div class="container-page grid gap-10 lg:grid-cols-3">
      <div class="lg:col-span-2">
        <p class="eyebrow">About the work</p>
        <h2 class="mt-3 font-display text-3xl font-semibold text-ink sm:text-4xl">
          Made by hand, refined on screen.
        </h2>
        <p class="mt-4 max-w-2xl text-base leading-relaxed text-ink-muted sm:text-lg">
          <!-- TODO: replace short intro -->
          This site collects sketchbook pages, finished pieces, digital illustrations,
          cartoonish drawings of people and animals, and animation studies. Everything is
          organized so new work can drop in easily — upload media to R2, add one line to the
          content file, and it shows up here.
        </p>
        <a href="/about" class="link-underline mt-5 inline-block text-sm font-medium">
          More about {site.shortName} →
        </a>
      </div>
      <dl class="grid grid-cols-2 gap-4 sm:grid-cols-4 lg:grid-cols-1 lg:gap-6">
        <div class="rounded-2xl border border-line bg-canvas-elevated p-4 shadow-soft">
          <dt class="text-xs uppercase tracking-wider text-ink-subtle">Physical</dt>
          <dd class="mt-1 font-display text-3xl font-semibold text-ink">{physicalArt.length}</dd>
        </div>
        <div class="rounded-2xl border border-line bg-canvas-elevated p-4 shadow-soft">
          <dt class="text-xs uppercase tracking-wider text-ink-subtle">Digital</dt>
          <dd class="mt-1 font-display text-3xl font-semibold text-ink">{digitalArt.length}</dd>
        </div>
        <div class="rounded-2xl border border-line bg-canvas-elevated p-4 shadow-soft">
          <dt class="text-xs uppercase tracking-wider text-ink-subtle">Cartoons</dt>
          <dd class="mt-1 font-display text-3xl font-semibold text-ink">{cartoons.length}</dd>
        </div>
        <div class="rounded-2xl border border-line bg-canvas-elevated p-4 shadow-soft">
          <dt class="text-xs uppercase tracking-wider text-ink-subtle">Animations</dt>
          <dd class="mt-1 font-display text-3xl font-semibold text-ink">{animations.length}</dd>
        </div>
      </dl>
    </div>
  </section>

  <!-- Featured grid -->
  <section class="section-y">
    <div class="container-page">
      <div class="mb-10 flex flex-col justify-between gap-4 sm:flex-row sm:items-end">
        <div>
          <p class="eyebrow">Selected work</p>
          <h2 class="mt-2 font-display text-3xl font-semibold text-ink">Featured pieces</h2>
        </div>
        <div class="flex flex-wrap gap-4 text-sm">
          <a href="/physical" class="link-underline">Physical</a>
          <a href="/digital" class="link-underline">Digital</a>
          <a href="/cartoons" class="link-underline">Cartoons</a>
          <a href="/animations" class="link-underline">Animations</a>
        </div>
      </div>
      <PhotoGrid items={featured} filterable={false} compact />
    </div>
  </section>

  <!-- CTA -->
  <section class="border-t border-line bg-ink text-canvas-elevated">
    <div class="container-page flex flex-col items-start justify-between gap-6 py-14 sm:flex-row sm:items-center sm:py-16">
      <div>
        <h2 class="font-display text-2xl font-semibold sm:text-3xl">Have a project in mind?</h2>
        <p class="mt-2 max-w-md text-sm text-white/70 sm:text-base">
          <!-- TODO: replace CTA copy -->
          Commissions, school collabs, or just a friendly note — say hello.
        </p>
      </div>
      <a
        href="/contact"
        class="inline-flex rounded-full bg-canvas-elevated px-5 py-2.5 text-sm font-medium text-ink transition hover:bg-accent-soft"
      >
        Contact
      </a>
    </div>
  </section>
</BaseLayout>
